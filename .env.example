# Azure DevOps Configuration
ADO_ORG=<your-ado-organization>
ADO_PROJECT=<your-ado-project>
ADO_PAT=<your-personal-access-token>

# HTTP Server
PORT=3000

# API Security — sent as the x-api-key header in Figma Make (or any HTTP client)
# Generate a strong random string, e.g.:  openssl rand -hex 32
API_KEY=<generate-a-strong-random-secret>
